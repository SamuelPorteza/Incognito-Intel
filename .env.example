# Copy this file to .env and fill in the values

  # PostgreSQL connection string (required)
  DATABASE_URL=postgresql://user:password@localhost:5432/incognito_intel

  # Secret used to sign session cookies (required) — use a long random string
  SESSION_SECRET=change-me-to-a-long-random-string

  # Node environment — use "development" locally, "production" in deployment
  NODE_ENV=development
  