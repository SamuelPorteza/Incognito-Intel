# Environment variables — never commit real secrets
  .env
  .env.local
  .env.*.local

  # Dependencies
  node_modules/
  .pnpm-store/

  # Build outputs
  dist/
  build/
  .next/
  out/

  # Drizzle generated migrations (keep schema, not snapshots)
  lib/db/drizzle/

  # TypeScript build cache
  *.tsbuildinfo

  # Logs
  *.log
  npm-debug.log*
  pnpm-debug.log*

  # OS artifacts
  .DS_Store
  Thumbs.db

  # Editor directories
  .vscode/
  .idea/
  *.swp
  *.swo

  # Replit internal
  .replit
  replit.nix
  .upm/
  .cache/
  